#!/usr/bin/env bash
# girginospanel-update — GirginOSPanel'i GitHub'dan güvenli in-place günceller.
#
#   girginospanel-update            # son sürümü çek → binary+frontend+migration değiştir → yeniden başlat
#   girginospanel-update --dry-run  # sadece ne yapacağını göster, dokunma
#   girginospanel-update --force    # binary aynı olsa bile yeniden uygula
#   girginospanel-update --branch X # farklı dal (varsayılan: main)
#
# KORUR (asla dokunmaz): /etc/girginospanel/env (JWT/DB/Redis secret),
# MariaDB `panel` DB + tüm müşteri verisi, /home/c_* siteleri.
# Yeni migration'lar servis yeniden başlarken otomatik + idempotent uygulanır.
#
# DB DAYANIKLILIĞI:
#  • Migration'lardan ÖNCE panel DB'sinin tam dump'ı alınır (/var/backups/girginospanel/db).
#  • FAIL-CLOSED: dump alınamazsa güncelleme HİÇ BAŞLAMAZ (yedeksiz migration reddedilir).
#  • Yeni sürüm sağlıklı başlamazsa ESKİ binary'ye + güncelleme öncesi DB'ye rollback yapar.
#  • Günlük 03:30 yedek timer'ı (girginospanel-db-backup.timer) kurulur + enable edilir.
set -euo pipefail

REPO="${GOSP_REPO:-girginos/gpanel}"
BRANCH="main"; DRY=0; FORCE=0
PREFIX=/opt/girginospanel
BIN="$PREFIX/bin/girginospanel-server"
SEED="$PREFIX/bin/girginospanel-seed-admin"
FDIST="$PREFIX/frontend-dist"
MIGR="$PREFIX/src/migrations"
SCRIPTS="$PREFIX/src/scripts"
DBBK=/usr/local/bin/girginospanel-db-backup   # panel DB dump aracı (assets/ops'tan kurulur)
DBDIR=/var/backups/girginospanel/db           # dump'ların yeri (kardeş dizinler = domain yedeği)
PREDUMP=""                                    # güncelleme öncesi dump yolu (rollback'te geri yüklenir)

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY=1 ;;
    --force) FORCE=1 ;;
    --branch) BRANCH="$2"; shift ;;
    --branch=*) BRANCH="${1#*=}" ;;
    -h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "bilinmeyen arg: $1" >&2; exit 2 ;;
  esac
  shift
done

c_b="\033[1;34m"; c_g="\033[32m"; c_r="\033[31m"; c_y="\033[33m"; c_0="\033[0m"
[ -t 1 ] || { c_b=; c_g=; c_r=; c_y=; c_0=; }
ok()   { echo -e "  ${c_g}✓${c_0} $*"; }
warn() { echo -e "  ${c_y}!${c_0} $*"; }
die()  { echo -e "${c_r}✗ $*${c_0}" >&2; exit 1; }
step() { echo -e "${c_b}══ $* ══${c_0}"; }

# çalışan panelin /healthz'inden sürüm (binary'nin --version flag'i YOK, asla çalıştırmıyoruz)
surum() { curl -fsS http://127.0.0.1:8080/healthz 2>/dev/null | grep -oE '"surum":"[^"]*"' | cut -d'"' -f4; }

[ "$(id -u)" = 0 ] || die "root gerekli (sudo girginospanel-update)"
[ -x "$BIN" ] || die "GirginOSPanel kurulu değil ($BIN yok) — önce install.sh çalıştırın"
command -v curl >/dev/null || die "curl gerekli"
command -v tar  >/dev/null || die "tar gerekli"

step "GirginOSPanel güncelleme (github.com/$REPO@$BRANCH)"

# 1) indir
TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT
echo "  indiriliyor…"
curl -fsSL "https://codeload.github.com/$REPO/tar.gz/refs/heads/$BRANCH" | tar xz -C "$TMP" \
  || die "indirme başarısız — repo public mi / '$BRANCH' dalı var mı?"
SRC=$(find "$TMP" -maxdepth 1 -type d -name "*-$BRANCH" | head -1)
A="$SRC/assets"
NEWBIN="$A/girginospanel-server"
[ -f "$NEWBIN" ] || die "$A/girginospanel-server yok (repo yapısı beklenenden farklı)"

# 2) yeni binary'yi ÇALIŞTIRMADAN doğrula (ELF header) + değişiklik tespiti.
# ÖNEMLİ: sadece binary'yi değil TÜM release'i (binary + frontend-dist + migrations)
# hash'le. Aksi halde frontend-only / migration-only bir güncellemede binary sha
# aynı kaldığı için güncelleme yanlışlıkla ATLANIRDI.
head -c4 "$NEWBIN" | grep -q $'\x7fELF' || die "indirilen binary geçerli ELF değil — iptal"
CURVER=$(surum); [ -n "$CURVER" ] || CURVER="?"
echo "  mevcut sürüm: $CURVER"
# NOT: her sha256sum'u cut ile SADECE hash'e indir — aksi halde çıktıdaki (rastgele
# tmp) dosya yolu RELHASH'i her çalıştırmada değiştirir ve no-op asla çalışmazdı.
RELHASH=$( { sha256sum "$NEWBIN" | cut -d' ' -f1
  [ -f "$A/frontend-dist.tar.gz" ] && sha256sum "$A/frontend-dist.tar.gz" | cut -d' ' -f1
  [ -f "$A/migrations.tar.gz" ] && sha256sum "$A/migrations.tar.gz" | cut -d' ' -f1
  # ops/ + systemd/ de hash'e DAHİL: aksi halde yalnızca script/unit değişen bir sürümde
  # (ör. DB yedek aracı + timer'ın eklenmesi) RELHASH sabit kalır ve güncelleme "zaten
  # en güncel" deyip sessizce ATLANIRDI — düzeltme sunucuya hiç ulaşmazdı.
  # LC_ALL=C sort: dosya sırası deterministik olmalı, yoksa hash her çalıştırmada oynar.
  find "$A/ops" "$A/systemd" -type f 2>/dev/null | LC_ALL=C sort \
    | xargs -r sha256sum 2>/dev/null | cut -d' ' -f1
  true; } | sha256sum | cut -d' ' -f1)
MARKER="$PREFIX/.release_hash"
CURREL=$(cat "$MARKER" 2>/dev/null || echo yok)
if [ "$RELHASH" = "$CURREL" ] && [ "$FORCE" = 0 ]; then
  ok "zaten en güncel (release hash eşleşti) — yapılacak bir şey yok (--force ile zorla)"
  exit 0
fi

if [ "$DRY" = 1 ]; then
  step "DRY-RUN — değişecekler (uygulanmadı)"
  echo "  • $BIN  (binary değişmişse swap + yedek $BIN.bak)"
  echo "  • $FDIST/  (frontend-dist yeniden yazılır)"
  echo "  • $MIGR/  (yeni .sql eklenir, mevcutlar korunur)"
  echo "  • /usr/local/bin ops-tool'lar + $SCRIPTS"
  echo "  • $DBBK + /etc/systemd/system/girginospanel-db-backup.{service,timer} (timer enable --now)"
  echo "  • migration'lardan ÖNCE panel DB dump'ı → $DBDIR  (DRY-RUN'da dump ALINMAZ)"
  echo "  • systemctl restart girginospanel  (env/DB/siteler KORUNUR)"
  exit 0
fi

# 3) DB yedek aracı + günlük timer'ı kur.
# SIRA ÖNEMLİ: dump'ı adım 4'te alacağız, aracın o an KURULU olması şart. Adım 9'daki
# genel ops döngüsü çok geç kalıyor (migration'lar adım 6'da çoktan açılmış olurdu) ve
# aracı hiç olmayan eski kurulumlarda dump imkânsız olurdu. Burada yalnızca db-backup'ı
# kuruyoruz — çalışan updater'ın kendi dosyasını bu noktada ezmiyoruz (bash script'i
# satır satır okur; kendini ortasından değiştirmek tehlikeli), o iş adım 9'da kalıyor.
if [ -f "$A/ops/girginospanel-db-backup" ]; then
  install -m 0755 "$A/ops/girginospanel-db-backup" "$DBBK"
  ok "DB yedek aracı kuruldu ($DBBK)"
fi
# systemd unit'leri: dosyayı kopyalamak YETMEZ — daemon-reload + enable --now olmadan
# timer asla ateşlenmez (kurulumda unutulursa günlük yedek sessizce hiç çalışmaz).
UNITS=0
for u in girginospanel-db-backup.service girginospanel-db-backup.timer; do
  if [ -f "$A/systemd/$u" ]; then install -m 0644 "$A/systemd/$u" "/etc/systemd/system/$u"; UNITS=1; fi
done
if [ "$UNITS" = 1 ]; then
  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl enable --now girginospanel-db-backup.timer >/dev/null 2>&1 || true
  if systemctl is-active --quiet girginospanel-db-backup.timer; then
    ok "günlük DB yedek timer'ı ACTIVE ($(systemctl show -p TimersCalendar --value girginospanel-db-backup.timer 2>/dev/null | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1))"
  else
    warn "DB yedek timer'ı başlatılamadı — günlük yedek çalışmayabilir"
  fi
fi

# 4) GÜNCELLEME ÖNCESİ DB DUMP — FAIL-CLOSED.
# Migration'lar geri alınamaz; yedeksiz migration kabul edilemez. Dump alınamıyorsa
# güncellemeye HİÇ BAŞLAMA (binary'ye, frontend'e, migration'lara dokunmadan çık).
step "Güncelleme öncesi DB yedeği"
[ -x "$DBBK" ] || die "DB yedek aracı yok/çalıştırılamıyor ($DBBK) — yedeksiz migration REDDEDİLDİ, güncelleme başlatılmadı"
PREDUMP=$("$DBBK") || die "güncelleme öncesi DB yedeği BAŞARISIZ — güncelleme başlatılmadı (DB'ye/binary'ye dokunulmadı)"
[ -n "$PREDUMP" ] && [ -f "$PREDUMP" ] \
  || die "güncelleme öncesi DB yedeği doğrulanamadı (dönen yol boş veya dosya yok) — güncelleme başlatılmadı"
ok "pre-update dump: $PREDUMP ($(du -h "$PREDUMP" 2>/dev/null | cut -f1))"

# 5) yedek (binary + seed)
cp -f "$BIN" "$BIN.bak"
[ -x "$SEED" ] && cp -f "$SEED" "$SEED.bak" 2>/dev/null || true
ok "mevcut binary yedeklendi ($BIN.bak)"

# 6) binary swap (install = atomik replace; çalışan process eski inode'u restart'a kadar tutar — cp -f KULLANMA)
install -m 0755 "$NEWBIN" "$BIN"
[ -f "$A/girginospanel-seed-admin" ] && install -m 0755 "$A/girginospanel-seed-admin" "$SEED"
ok "binary güncellendi"

# 7) frontend-dist
if [ -f "$A/frontend-dist.tar.gz" ]; then
  rm -rf "${FDIST:?}/"* && tar xzf "$A/frontend-dist.tar.gz" -C "$FDIST"
  ok "frontend-dist güncellendi"
fi

# 8) migration'lar (idempotent — startup'ta uygulanır). Adım 4'te dump'ı ALDIK.
if [ -f "$A/migrations.tar.gz" ]; then
  mkdir -p "$MIGR"; tar xzf "$A/migrations.tar.gz" -C "$MIGR"
  ok "migration'lar senkron ($(ls "$MIGR"/*.sql 2>/dev/null | wc -l) sql)"
fi

# 9) ops-tool'lar (updater kendini de günceller; db-backup adım 3'te zaten kuruldu — tekrar idempotent)
if [ -d "$A/ops" ]; then
  for t in "$A"/ops/*; do bn=$(basename "$t"); install -m 0755 "$t" "/usr/local/bin/${bn%.sh}" 2>/dev/null || true; done
  mkdir -p "$SCRIPTS"; cp "$A"/ops/* "$SCRIPTS/" 2>/dev/null || true
  ok "ops-tool'lar güncellendi"
fi

# 10) izolasyon + araç prereq (eski kurulumlarda yoksa gelsin; idempotent) + SELinux context
command -v bwrap >/dev/null 2>&1 || dnf install -y bubblewrap >/dev/null 2>&1 || true
# acl (setfacl): per-user dosya izin modeli (nginx user-ACL) için ŞART — yoksa panel fail-safe
# grup=nginx moduna düşer. Idempotent.
command -v setfacl >/dev/null 2>&1 || dnf install -y acl >/dev/null 2>&1 || true
# RAR açıcı (dosya yöneticisi .rar extract): PRİMER bsdtar (libarchive, base repo, güvenilir
# RAR/RAR5 + path-traversal reddeder). 7z (7-Zip 26.02) RAR codec içermez → kullanılmaz.
if ! command -v bsdtar >/dev/null 2>&1 && ! command -v unar >/dev/null 2>&1 && ! command -v unrar >/dev/null 2>&1; then
  dnf install -y bsdtar >/dev/null 2>&1 || dnf install -y unar >/dev/null 2>&1 || dnf install -y unrar >/dev/null 2>&1 || true
fi
command -v restorecon >/dev/null && restorecon -R "$PREFIX/bin" "$FDIST" >/dev/null 2>&1 || true

# 10b) Disk kotası (XFS user quota) GRUB yapılandırma — 🔴 CANLI SUNUCU: OTO-REBOOT ETME.
# Kök fs XFS + noquota ise `rootflags=uquota`'yı /etc/default/grub'a idempotent yaz; kota ancak
# MOUNT anında (reboot ile) açılır. Reboot'u OPERATÖR zamanlar → sentinel dosyası + net uyarı
# bırak. Panel açılışındaki HealKotaOnStartup, fs kota aktif olduğunda limitleri kendi uygular.
command -v quota >/dev/null 2>&1 || dnf install -y quota xfsprogs >/dev/null 2>&1 || true
QROOTFS=$(findmnt -no FSTYPE / 2>/dev/null || echo "")
QROOTOPTS=$(findmnt -no OPTIONS / 2>/dev/null || echo "")
QSENTINEL=/etc/girginospanel/reboot-required-quota
if [ "$QROOTFS" = "xfs" ] && ! echo "$QROOTOPTS" | grep -qwE 'usrquota|uquota|quota'; then
  if ! grep -q 'rootflags=uquota' /etc/default/grub 2>/dev/null; then
    if grep -q '^GRUB_CMDLINE_LINUX=' /etc/default/grub 2>/dev/null; then
      sed -i 's/^\(GRUB_CMDLINE_LINUX="[^"]*\)"/\1 rootflags=uquota"/' /etc/default/grub
    else
      echo 'GRUB_CMDLINE_LINUX="rootflags=uquota"' >> /etc/default/grub
    fi
    command -v grubby >/dev/null 2>&1 && grubby --update-kernel=ALL --args="rootflags=uquota" >/dev/null 2>&1 || true
    grub2-mkconfig -o /boot/grub2/grub.cfg >/dev/null 2>&1 || true
    for cfg in /boot/efi/EFI/*/grub.cfg; do [ -f "$cfg" ] && grub2-mkconfig -o "$cfg" >/dev/null 2>&1 || true; done
  fi
  mkdir -p /etc/girginospanel
  echo "rootflags=uquota GRUB'a yazildi $(date -Is 2>/dev/null) — reboot bekleniyor" > "$QSENTINEL" 2>/dev/null || true
  warn "🔴 Disk kotası GRUB'a yazıldı — AKTİF olması için tek seferlik REBOOT gerekli (canlı sunucuda operatör zamanlar). OTO-REBOOT YAPILMADI."
elif [ "$QROOTFS" = "xfs" ]; then
  [ -f "$QSENTINEL" ] && rm -f "$QSENTINEL" 2>/dev/null && ok "disk kotası aktif — reboot sentinel temizlendi" || ok "disk kotası aktif (kök XFS user quota)"
fi

# 11) yeniden başlat + sağlık kontrolü (başarısızsa binary + DB rollback)
step "Yeniden başlatılıyor"
systemctl restart girginospanel
HEALTHY=0
for i in 1 2 3 4 5 6; do
  sleep 2
  if systemctl is-active --quiet girginospanel && curl -fsS http://127.0.0.1:8080/healthz >/dev/null 2>&1; then HEALTHY=1; break; fi
done

if [ "$HEALTHY" = 1 ]; then
  systemctl reload nginx >/dev/null 2>&1 || true
  echo "$RELHASH" > "$MARKER" 2>/dev/null || true   # bu release'i uygulandı olarak işaretle
  NEWVER=$(surum); [ -n "$NEWVER" ] || NEWVER="?"
  ok "panel ACTIVE + /healthz OK"
  ok "kaynak limitleri planlardan uygulanıyor + mevcut siteler per-tenant PHP-FPM izolasyonuna GÜVENLE (self-check + auto-rollback) geçiriliyor (arka planda)"
  echo -e "${c_g}══ Güncelleme tamam ($CURVER → $NEWVER) — env/DB/siteler korundu ══${c_0}"
else
  warn "yeni sürüm sağlıklı başlamadı — ESKİ binary'ye + güncelleme öncesi DB'ye dönülüyor"
  install -m 0755 "$BIN.bak" "$BIN"
  [ -f "$SEED.bak" ] && install -m 0755 "$SEED.bak" "$SEED" 2>/dev/null || true
  command -v restorecon >/dev/null && restorecon "$BIN" >/dev/null 2>&1 || true

  # DB'yi de geri yükle: yeni sürümün migration'ı şemayı değiştirmiş olabilir ve ESKİ
  # binary o şemayla çalışamaz → binary-only rollback yetmez. Panel şu an DURMUŞ
  # (restart sağlıksız kaldı) → geri yükleme sırasında yazma kaybı yok.
  # NOT: dump `--databases panel` ile alındı → her tablo için DROP+CREATE içerir; yeni
  # migration'ın EKLEDİĞİ tablolar dump'ta olmadığı için kalır (eski binary onları
  # görmez, zararsız). Kolon/veri değişiklikleri geri alınır.
  systemctl stop girginospanel >/dev/null 2>&1 || true
  if [ -n "$PREDUMP" ] && [ -f "$PREDUMP" ]; then
    if zcat "$PREDUMP" | mysql; then
      ok "DB güncelleme öncesi yedeğe geri yüklendi ($PREDUMP)"
    else
      warn "DB geri yükleme BAŞARISIZ — dump duruyor, elle: zcat '$PREDUMP' | mysql"
    fi
  else
    warn "güncelleme öncesi dump bulunamadı — yalnızca binary geri alındı"
  fi

  systemctl restart girginospanel; sleep 3
  if systemctl is-active --quiet girginospanel; then
    die "rollback yapıldı — panel ESKİ sürüm + ESKİ DB ile ayakta. Yeni sürüm hatası: journalctl -u girginospanel -n 40"
  else
    die "KRİTİK: rollback sonrası da panel kalkmadı — journalctl -u girginospanel -n 40 (DB yedeği: $PREDUMP)"
  fi
fi
