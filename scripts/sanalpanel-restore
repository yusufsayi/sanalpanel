#!/usr/bin/env bash
# sanalpanel-restore — SanalPanel CORE dosyalarını canonical sürümden ONARIR.
#
# AMAÇ (sanalpanel-update'ten FARKI):
#   • "onar", "en son sürüme yükselt" DEĞİL — çalışan sürümün BOZULMUŞ core dosyalarını
#     (0-byte frontend, silinmiş/bozuk binary, eksik ops-tool) canonical release ile eşitler.
#   • INTEGRITY-FIRST / FORCE: release hash aynı olsa bile bütünlük bozuksa (boş/eksik/ELF değil)
#     yine de geri yükler. Update ise hash eşleşince "zaten güncel" deyip ATLAR.
#
#   sanalpanel-restore              # core'u canonical (main) ile onar → gerekliyse restart
#   sanalpanel-restore --dry-run    # sadece teşhis + ne yapılacağını göster, HİÇBİR ŞEYE dokunma
#   sanalpanel-restore --branch X   # farklı dal (varsayılan: main)
#   sanalpanel-restore --no-db-dump # migration-öncesi DB dump'ını atla (acil durum; DİKKAT)
#   sanalpanel-restore --no-restart # dosyaları onar ama servisi yeniden başlatma
#
# KORUR (repair ASLA dokunmaz — ne siler ne değiştirir):
#   • /etc/sanalpanel/env        (JWT / DB / Redis secret'ları)
#   • MariaDB `panel` DB + TÜM müşteri verisi
#   • /home/c_*                     (müşteri siteleri)
#   • /var/backups/sanalpanel/*  (mevcut yedekler — sadece güvenlik için YENİ dump EKLER)
# Yalnızca şu core yolları yazar: $BIN, $SEED, $FDIST, $MIGR (ekler), $SCRIPTS, /usr/local/bin ops.
#
# GÜVENLİK: frontend + binary ATOMİK + BÜTÜNLÜK-DOĞRULANMIŞ swap ile devreye alınır. Bozuk/kesik
# indirme çalışan dosyaya ASLA dokunmaz (0-byte outage önlemi — sanalpanel-update ile aynı desen).
# Migration'lar servis restart'ında uygulanır → önce FAIL-CLOSED DB dump alınır; sağlıksız
# başlarsa eski binary + güncelleme-öncesi DB'ye rollback yapılır.
set -euo pipefail

REPO="${SANAL_REPO:-sanalpanel/sanalpanel}"
BRANCH="main"; DRY=0; DODB=1; DORESTART=1

# Yollar env ile override edilebilir (izole test için). Üretimde varsayılanlar geçerli.
PREFIX="${SANAL_PREFIX:-/opt/sanalpanel}"
BIN="${SANAL_BIN:-$PREFIX/bin/sanalpanel-server}"
SEED="${SANAL_SEED:-$PREFIX/bin/sanalpanel-seed-admin}"
FDIST="${SANAL_FDIST:-$PREFIX/frontend-dist}"
MIGR="${SANAL_MIGR:-$PREFIX/src/migrations}"
SCRIPTS="${SANAL_SCRIPTS:-$PREFIX/src/scripts}"
OPSBIN="${SANAL_OPSBIN:-/usr/local/bin}"
SVC="${SANAL_SVC:-sanalpanel}"
HEALTH="${SANAL_HEALTH:-http://127.0.0.1:8080/healthz}"
DBBK="${SANAL_DBBK:-/usr/local/bin/sanalpanel-db-backup}"  # panel DB dump aracı
DBDIR="${SANAL_DBDIR:-/var/backups/sanalpanel/db}"         # dump'ların yeri
PREDUMP=""                                                    # onarım-öncesi dump (rollback'te geri yüklenir)

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY=1 ;;
    --branch) BRANCH="$2"; shift ;;
    --branch=*) BRANCH="${1#*=}" ;;
    --no-db-dump) DODB=0 ;;
    --no-restart) DORESTART=0 ;;
    -h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "bilinmeyen arg: $1" >&2; exit 2 ;;
  esac
  shift
done

c_b="\033[1;34m"; c_g="\033[32m"; c_r="\033[31m"; c_y="\033[33m"; c_0="\033[0m"
[ -t 1 ] || { c_b=; c_g=; c_r=; c_y=; c_0=; }
ok()   { echo -e "  ${c_g}✓${c_0} $*"; }
warn() { echo -e "  ${c_y}!${c_0} $*"; }
die()  { echo -e "${c_r}✗ $*${c_0}" >&2; exit 1; }
step() { echo -e "${c_b}══ $* ══${c_0}"; }

is_elf() { head -c4 "$1" 2>/dev/null | grep -q $'\x7fELF'; }

[ "$(id -u)" = 0 ] || die "root gerekli (sudo sanalpanel-restore)"
command -v curl >/dev/null || die "curl gerekli"
command -v tar  >/dev/null || die "tar gerekli"

step "SanalPanel core onarım (github.com/$REPO@$BRANCH)$([ $DRY = 1 ] && echo '  [DRY-RUN]')"

# ───────────────────────────────────────────────────────────────────────────
# a) Canonical release'i getir → $A (assets dizini).
#    SANAL_ASSETS_OVERRIDE ayarlıysa indirme ATLANIR (izole/offline test).
# ───────────────────────────────────────────────────────────────────────────
if [ -n "${SANAL_ASSETS_OVERRIDE:-}" ]; then
  A="$SANAL_ASSETS_OVERRIDE"
  [ -d "$A" ] || die "SANAL_ASSETS_OVERRIDE dizini yok: $A"
  warn "TEST/OFFLINE: indirme atlandı, yerel assets kullanılıyor ($A)"
else
  echo "  indiriliyor…"
  TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT
  curl -fsSL "https://codeload.github.com/$REPO/tar.gz/refs/heads/$BRANCH" | tar xz -C "$TMP" \
    || die "indirme başarısız — repo public mi / '$BRANCH' dalı var mı?"
  SRC=$(find "$TMP" -maxdepth 1 -type d -name "*-$BRANCH" | head -1)
  [ -n "$SRC" ] || die "indirilen arşiv boş/beklenmedik yapı — onarım iptal"
  A="$SRC/assets"
fi
[ -d "$A" ] || die "assets/ bulunamadı ($A) — repo yapısı beklenenden farklı"
NEWBIN="$A/sanalpanel-server"
[ -f "$NEWBIN" ] || die "$NEWBIN yok — canonical release bozuk/eksik, onarım iptal"

# ───────────────────────────────────────────────────────────────────────────
# b) BÜTÜNLÜK TEŞHİSİ (önce göster — neyin bozuk olduğunu operatör görsün).
# ───────────────────────────────────────────────────────────────────────────
step "Mevcut kurulum teşhisi"
FE_BAD=0; BIN_BAD=0
if [ -s "$FDIST/index.html" ] && ls "$FDIST"/assets/index-*.js >/dev/null 2>&1; then
  ok "frontend-dist sağlam (index.html dolu + JS bundle var)"
else
  FE_BAD=1; warn "frontend-dist BOZUK/EKSİK (index.html boş ya da JS bundle yok) — onarılacak"
fi
if [ -f "$BIN" ] && is_elf "$BIN" && [ -x "$BIN" ]; then
  ok "server binary sağlam (ELF + çalıştırılabilir)"
else
  BIN_BAD=1; warn "server binary BOZUK/EKSİK (yok / ELF değil / çalıştırılamaz) — onarılacak"
fi
MISS_OPS=""
if [ -d "$A/ops" ]; then
  for t in "$A"/ops/*; do
    bn=$(basename "$t"); nm="${bn%.sh}"
    [ -x "$OPSBIN/$nm" ] || MISS_OPS="$MISS_OPS $nm"
  done
fi
if [ -n "$MISS_OPS" ]; then warn "eksik ops-tool'lar:$MISS_OPS — kurulacak"; else ok "ops-tool'lar tam"; fi

if [ "$DRY" = 1 ]; then
  step "DRY-RUN — onarılacaklar (uygulanmadı, HİÇBİR ŞEYE dokunulmadı)"
  echo "  • $FDIST/  → canonical'den atomik+doğrulanmış swap (her koşulda yenilenir)"
  echo "  • $BIN     → $([ $BIN_BAD = 1 ] && echo 'BOZUK: canonical binary ile değiştirilir' || echo 'canonical ile eşitlenir (farklıysa)') (+ $BIN.bak)"
  echo "  • $SEED    → canonical seed-admin ile eşitlenir"
  echo "  • $MIGR/   → yeni .sql EKLENİR (mevcutlar korunur)"
  echo "  • $OPSBIN + $SCRIPTS → ops-tool'lar senkron"
  echo "  • KORUNUR: /etc/sanalpanel/env · panel DB · /home/c_* · /var/backups/sanalpanel/*"
  [ $DODB = 1 ] && echo "  • restart öncesi FAIL-CLOSED DB dump → $DBDIR (DRY-RUN'da ALINMAZ)"
  [ $DORESTART = 1 ] && echo "  • systemctl restart $SVC + /healthz (sağlıksızsa binary+DB rollback)"
  exit 0
fi

# ───────────────────────────────────────────────────────────────────────────
# c) frontend-dist — ATOMİK + DOĞRULANMIŞ swap (sanalpanel-update deseni).
#    Yeni sürüm ayrı geçici dizine açılır → index.html DOLU + JS bundle DOĞRULANIR →
#    atomik mv. Bozuk/kesik extraction çalışan frontend'e ASLA dokunmaz.
# ───────────────────────────────────────────────────────────────────────────
if [ -f "$A/frontend-dist.tar.gz" ]; then
  step "frontend-dist onarımı"
  FDNEW="${FDIST}.new.$$"
  rm -rf "$FDNEW"; mkdir -p "$FDNEW"
  fdist_abort() { rm -rf "$FDNEW" 2>/dev/null || true; die "$1"; }
  if ! tar xzf "$A/frontend-dist.tar.gz" -C "$FDNEW"; then
    fdist_abort "frontend-dist extraction başarısız — MEVCUT frontend KORUNDU (dokunulmadı)"
  fi
  # bütünlük kapısı: index.html DOLU + en az bir JS bundle (0-byte/kesik tarball reddedilir)
  if [ ! -s "$FDNEW/index.html" ] || ! ls "$FDNEW"/assets/index-*.js >/dev/null 2>&1; then
    fdist_abort "indirilen frontend-dist BOZUK (index.html/JS boş veya eksik) — MEVCUT frontend KORUNDU"
  fi
  rm -rf "${FDIST}.old"
  [ -d "$FDIST" ] && mv "$FDIST" "${FDIST}.old"
  mkdir -p "$(dirname "$FDIST")"
  mv "$FDNEW" "$FDIST"
  sync   # reboot-güvenli: delayed-alloc veri kaybını (0-byte) önlemek için diske flush
  ok "frontend-dist onarıldı (atomik doğrulanmış swap)"
else
  warn "canonical'de frontend-dist.tar.gz yok — frontend atlandı"
fi

# ───────────────────────────────────────────────────────────────────────────
# d) binary + seed — ELF + boyut>1MB DOĞRULA → .bak yedekle → atomik değiştir.
#    ÇALIŞAN binary'yi cp -f ile EZME (TLS-EOF tuzağı): install(1) = atomik rename,
#    çalışan process eski inode'u restart'a kadar tutar.
# ───────────────────────────────────────────────────────────────────────────
step "server binary onarımı"
is_elf "$NEWBIN" || die "indirilen binary geçerli ELF değil — binary onarımı iptal (mevcut korundu)"
NSZ=$(stat -c%s "$NEWBIN" 2>/dev/null || echo 0)
[ "$NSZ" -gt 1048576 ] || die "indirilen binary şüpheli küçük ($NSZ bayt ≤1MB) — onarım iptal (mevcut korundu)"
mkdir -p "$(dirname "$BIN")"
DO_BIN=1
if [ "$BIN_BAD" = 0 ] && [ -f "$BIN" ] && cmp -s "$NEWBIN" "$BIN"; then
  DO_BIN=0; ok "binary zaten canonical ile birebir aynı — değiştirilmedi"
fi
if [ "$DO_BIN" = 1 ]; then
  [ -f "$BIN" ] && cp -f "$BIN" "$BIN.bak" && ok "mevcut binary yedeklendi ($BIN.bak)" || warn "yedeklenecek mevcut binary yok (ilk kurulum gibi)"
  install -m 0755 "$NEWBIN" "$BIN"
  ok "binary canonical'den devreye alındı (atomik)"
fi
if [ -f "$A/sanalpanel-seed-admin" ]; then
  if is_elf "$A/sanalpanel-seed-admin"; then
    [ -f "$SEED" ] && cp -f "$SEED" "$SEED.bak" 2>/dev/null || true
    install -m 0755 "$A/sanalpanel-seed-admin" "$SEED"
    ok "seed-admin eşitlendi"
  else
    warn "canonical seed-admin ELF değil — atlandı"
  fi
fi

# ───────────────────────────────────────────────────────────────────────────
# e) ops-tool'lar + src/scripts + migration'lar. Migration'lar EKLENİR (mevcut korunur).
# ───────────────────────────────────────────────────────────────────────────
if [ -f "$A/migrations.tar.gz" ]; then
  mkdir -p "$MIGR"; tar xzf "$A/migrations.tar.gz" -C "$MIGR"
  ok "migration'lar senkron ($(ls "$MIGR"/*.sql 2>/dev/null | wc -l) sql, mevcutlar korundu)"
elif [ -d "$A/migrations" ]; then
  mkdir -p "$MIGR"; cp -n "$A"/migrations/*.sql "$MIGR/" 2>/dev/null || true
  ok "migration'lar senkron (dizinden)"
fi
if [ -d "$A/ops" ]; then
  mkdir -p "$OPSBIN" "$SCRIPTS"
  for t in "$A"/ops/*; do bn=$(basename "$t"); install -m 0755 "$t" "$OPSBIN/${bn%.sh}" 2>/dev/null || true; done
  cp "$A"/ops/* "$SCRIPTS/" 2>/dev/null || true
  ok "ops-tool'lar + src/scripts senkron"
fi
command -v restorecon >/dev/null && restorecon -R "$(dirname "$BIN")" "$FDIST" >/dev/null 2>&1 || true

# ───────────────────────────────────────────────────────────────────────────
# f/g) restart + healthcheck + rollback. Migration'lar restart'ta uygulanır → önce
#      FAIL-CLOSED DB dump. Sağlıksız başlarsa eski binary + onarım-öncesi DB'ye dön.
# ───────────────────────────────────────────────────────────────────────────
if [ "$DORESTART" = 0 ]; then
  step "Onarım tamam — servis yeniden başlatılmadı (--no-restart)"
  ok "core dosyalar canonical ile eşitlendi (env/DB/siteler/yedekler korundu)"
  exit 0
fi

if [ "$DODB" = 1 ]; then
  step "Restart öncesi DB yedeği (FAIL-CLOSED)"
  if [ -x "$DBBK" ]; then
    PREDUMP=$("$DBBK") || die "onarım-öncesi DB yedeği BAŞARISIZ — restart yapılmadı (dosyalar onarıldı, DB'ye dokunulmadı)"
    [ -n "$PREDUMP" ] && [ -f "$PREDUMP" ] || die "onarım-öncesi DB yedeği doğrulanamadı — restart yapılmadı"
    ok "pre-repair dump: $PREDUMP ($(du -h "$PREDUMP" 2>/dev/null | cut -f1))"
  else
    die "DB yedek aracı yok ($DBBK) — yedeksiz migration reddedildi. Acil: --no-db-dump ile atla (DİKKAT) veya --no-restart"
  fi
else
  warn "DB dump ATLANDI (--no-db-dump) — restart migration uygularsa geri dönüşü olmayabilir"
fi

step "Yeniden başlatılıyor"
systemctl restart "$SVC"
HEALTHY=0
for i in 1 2 3 4 5 6; do
  sleep 2
  if systemctl is-active --quiet "$SVC" && curl -fsS "$HEALTH" >/dev/null 2>&1; then HEALTHY=1; break; fi
done

if [ "$HEALTHY" = 1 ]; then
  systemctl reload nginx >/dev/null 2>&1 || true
  ok "panel ACTIVE + /healthz OK"
  echo -e "${c_g}══ Onarım tamam — core canonical'e getirildi (env/DB/siteler/yedekler korundu) ══${c_0}"
else
  warn "onarım sonrası sağlıklı başlamadı — ESKİ binary'ye + onarım-öncesi DB'ye dönülüyor"
  [ -f "$BIN.bak" ] && install -m 0755 "$BIN.bak" "$BIN"
  [ -f "$SEED.bak" ] && install -m 0755 "$SEED.bak" "$SEED" 2>/dev/null || true
  command -v restorecon >/dev/null && restorecon "$BIN" >/dev/null 2>&1 || true
  systemctl stop "$SVC" >/dev/null 2>&1 || true
  if [ -n "$PREDUMP" ] && [ -f "$PREDUMP" ]; then
    if zcat "$PREDUMP" | mysql; then ok "DB onarım-öncesi yedeğe geri yüklendi ($PREDUMP)"
    else warn "DB geri yükleme BAŞARISIZ — elle: zcat '$PREDUMP' | mysql"; fi
  fi
  systemctl restart "$SVC"; sleep 3
  if systemctl is-active --quiet "$SVC"; then
    die "rollback yapıldı — panel ESKİ sürüm + ESKİ DB ile ayakta. Hata: journalctl -u $SVC -n 40"
  else
    die "KRİTİK: rollback sonrası da panel kalkmadı — journalctl -u $SVC -n 40 (DB yedeği: $PREDUMP)"
  fi
fi
